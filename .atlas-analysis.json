  "publicApiSurface": [
    "GET /api/conversations - Get all conversations for authenticated user",
    "POST /api/conversations - Create a new conversation",
    "DELETE /api/conversations - Delete a conversation by ID",
    "GET /api/conversations/get-one-by-public-id - Get conversation by ID",
    "POST /api/conversations/mark-as-read - Mark conversation as read",
    "POST /api/messages/send - Send a message with optional file attachment",
    "GET /api/users/get-authenticated-user - Get authenticated user details",
    "GET /api/users/search - Search users by query",
    "GET /api/users/get-last-seen - Get user's last seen timestamp"
